{
  "name": "@appza/renderer",
  "version": "0.0.0",
  "private": true,
  "description": "Shared renderer — turns a TemplateScreen + catalog into Ionic React JSX. One implementation drives both the Capacitor mobile app and the WP-admin simulator.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@appza/schemas": "workspace:*",
    "@ionic/react": "^8.4.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
